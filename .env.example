# ── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=995283

# Comma-separated Telegram user IDs who can manage the whitelist
# Find your ID by messaging @userinfobot on Telegram
ADMIN_TELEGRAM_IDS=123456789,987654321

# ── Google Meet ───────────────────────────────────────────────────────────────
# Path to the credentials.json downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json

# Where to store the OAuth token used by runtime (create it via create_token.py)
GOOGLE_TOKEN_FILE=token.json

# ── Whitelist ─────────────────────────────────────────────────────────────────
# Path to the persistent whitelist JSON file (auto-created)
WHITELIST_FILE=whitelist.json

# Comma-separated user IDs that are always seeded into whitelist at startup
# Useful for stateless/ephemeral deployments
DEFAULT_WHITELIST_IDS=123456789
